#!/bin/bash
# predator-mode — Performance mode manager for Acer Predator Helios Neo 16 AI
# Usage: sudo predator-mode [turbo|balanced|status|toggle]

P=/proc/acpi/call
STATE_FILE=/var/tmp/predator_mode

load_module() {
    if [ ! -f "$P" ]; then
        modprobe acpi_call 2>/dev/null || { echo "ERROR: failed to load acpi_call module"; exit 1; }
    fi
}

show_status() {
    local mode="unknown"
    [ -f "$STATE_FILE" ] && mode=$(cat "$STATE_FILE")
    echo "Current mode : $mode"
    echo "GPU          : $(nvidia-smi --query-gpu=power.draw,power.limit --format=csv,noheader 2>/dev/null || echo 'nvidia-smi unavailable')"
    echo "CPU governor : $(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_governor 2>/dev/null || echo 'unavailable')"
}

set_turbo() {
    load_module
    printf '\\_SB_.PC00.WMID.WMBH 0x01 0x16 {0x0B,0x05,0x00,0x00,0x00,0x00,0x00,0x00}\n' > "$P"
    echo "WMBH (Turbo) : $(cat $P)"
    printf '\\_SB_.NPCF.ACBT\n' > "$P"; echo "ACBT         : $(cat $P)"
    printf '\\_SB_.NPCF.NVWM\n' > "$P"; echo "NVWM         : $(cat $P)"
    systemctl start nvidia-powerd 2>/dev/null && echo "nvidia-powerd: started (GPU 115W)"
    echo turbo > "$STATE_FILE"
    echo ""
    show_status
}

set_balanced() {
    load_module
    printf '\\_SB_.PC00.WMID.WMBH 0x01 0x16 {0x0B,0x01,0x00,0x00,0x00,0x00,0x00,0x00}\n' > "$P"
    echo "WMBH (Balanced): $(cat $P)"
    systemctl stop nvidia-powerd 2>/dev/null && echo "nvidia-powerd: stopped (GPU back to 80W)"
    echo balanced > "$STATE_FILE"
    echo ""
    show_status
}

toggle() {
    local current="balanced"
    [ -f "$STATE_FILE" ] && current=$(cat "$STATE_FILE")
    if [ "$current" = "turbo" ]; then
        echo "Switching: turbo → balanced"
        set_balanced
    else
        echo "Switching: balanced → turbo"
        set_turbo
    fi
}

[ "$(id -u)" -ne 0 ] && { echo "Run as root: sudo predator-mode $*"; exit 1; }

case "${1:-toggle}" in
    turbo)    set_turbo ;;
    balanced) set_balanced ;;
    status)   load_module; show_status ;;
    toggle)   toggle ;;
    *)
        echo "Usage: sudo predator-mode [turbo|balanced|status|toggle]"
        echo "  turbo    — GPU 115W + max fans + purple LED"
        echo "  balanced — GPU 80W + normal fans + blue LED"
        echo "  status   — show current mode, GPU power and CPU governor"
        echo "  toggle   — switch between turbo and balanced (default)"
        exit 1
        ;;
esac
